# Variables de entorno para base de datos remota
# Configurar estos valores según tu servidor de base de datos

# Configuración de base de datos remota
DB_HOST=tu-servidor-mysql.com
DB_PORT=3306
DB_NAME=leon_express
DB_USER=tu_usuario_mysql
DB_PASSWORD=tu_password_mysql

# Configuración de JWT
JWT_SECRET=tu_jwt_secret_super_seguro_aqui

# Configuración de push notifications (VAPID)
VAPID_PUBLIC_KEY=tu_vapid_public_key_aqui
VAPID_PRIVATE_KEY=tu_vapid_private_key_aqui

# Opcional: Configuración adicional
NODE_ENV=production